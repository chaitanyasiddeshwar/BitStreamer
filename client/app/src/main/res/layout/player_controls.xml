<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom Media3 controller layout. Based on the default styled controller, but
  reordered/trimmed for TV D-pad use (see PlayerActivity + docs/MEDIA3.md):
    time bar  = default focus  -> D-pad LEFT/RIGHT scrubs, OK commits the seek
    DOWN      -> options row (Audio / Subtitles / Chapters)
  No center transport buttons: play/pause is the OK key on the clean frame, and
  seeking is the D-pad, so the middle-of-screen rew/play/ffwd cluster is omitted.
  IDs prefixed exo_ are wired automatically by Media3; btn_* by PlayerActivity.
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <View
        android:id="@id/exo_controls_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000" />

    <!-- Bottom stack: time bar + options row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#66000000"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@id/exo_position"
                style="@style/ExoStyledControls.TimeText.Position" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:nextFocusDown="@id/btn_audio"
                app:ad_marker_color="#FFFFFFFF"
                app:played_ad_marker_color="#FFFFFFFF" />

            <!-- Not @id/exo_duration: Media3 auto-fills that with total duration.
                 We take over this label and show time *remaining* instead (see
                 remainingRefresh in PlayerActivity). -->
            <TextView
                android:id="@+id/time_remaining"
                style="@style/ExoStyledControls.TimeText.Duration" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/options_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <!-- Left/right focus among these is left to default geometry traversal,
                 so a hidden Chapters button doesn't break the chain. -->
            <ImageButton
                android:id="@+id/btn_audio"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:padding="8dp"
                android:background="@drawable/options_btn_bg"
                android:src="@drawable/ic_audio"
                android:scaleType="fitCenter"
                android:contentDescription="@string/opt_audio"
                android:nextFocusUp="@id/exo_progress" />

            <ImageButton
                android:id="@+id/btn_subtitles"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:padding="8dp"
                android:background="@drawable/options_btn_bg"
                android:src="@drawable/ic_subtitles"
                android:scaleType="fitCenter"
                android:contentDescription="@string/opt_subtitles"
                android:nextFocusUp="@id/exo_progress" />

            <ImageButton
                android:id="@+id/btn_chapters"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:padding="8dp"
                android:background="@drawable/options_btn_bg"
                android:src="@drawable/ic_chapters"
                android:scaleType="fitCenter"
                android:contentDescription="@string/opt_chapters"
                android:nextFocusUp="@id/exo_progress"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_stats"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:padding="8dp"
                android:background="@drawable/options_btn_bg"
                android:src="@drawable/ic_stats"
                android:scaleType="fitCenter"
                android:contentDescription="@string/opt_stats"
                android:nextFocusUp="@id/exo_progress" />
        </LinearLayout>
    </LinearLayout>
</merge>
