<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground focus indicator for the center transport buttons. Drawn ON TOP
     of each button's icon (via android:foreground) so the icon stays visible
     while a clear ring + tint marks which control is selected. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFFFFF" />
            <stroke android:width="3dp" android:color="#FFFFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>
</selector>
